# --- Database ---
POSTGRES_USER=dental
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=dental_ai
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://dental:changeme_in_production@db:5432/dental_ai

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=please-generate-with-openssl-rand-hex-32

# --- AI providers (almeno una richiesta) ---
DEFAULT_AI_PROVIDER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GOOGLE_API_KEY=
# Chiave AI Studio dedicata a Gemini Image (Nano Banana). Lascia vuota per riusare GOOGLE_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Scientific ingest ---
PUBMED_EMAIL=your-email@example.com
PUBMED_API_KEY=
PUBMED_QUERY=(artificial intelligence[Title/Abstract] OR deep learning[Title/Abstract] OR machine learning[Title/Abstract]) AND (dentistry[Title/Abstract] OR dental[Title/Abstract] OR orthodontic[Title/Abstract] OR endodontic[Title/Abstract] OR periodont[Title/Abstract] OR implant[Title/Abstract])
INGEST_INTERVAL_HOURS=12
INGEST_MAX_PER_RUN=20

# --- Validation thresholds ---
CAPTION_MAX_CHARS=2200
HASHTAG_MAX_COUNT=30
CAROUSEL_MIN_SLIDES=4
CAROUSEL_MAX_SLIDES=10
REQUIRE_CLINICAL_DISCLAIMER=true

# --- Personal brand (usato nei prompt e nel rendering immagini) ---
AUTHOR_NAME=Dr. Example
INSTAGRAM_HANDLE=@dr.example
BRAND_TAGLINE=Dentistry × Artificial Intelligence
BRAND_VOICE=scientific yet accessible, professional, modern, elegant
# Lingua dei contenuti generati: en (inglese) o it (italiano)
CONTENT_LANGUAGE=en

# --- Image generation / search ---
#   "pollinations" = Flux via pollinations.ai — GRATIS, no auth (default)
#   "ai"           = Imagen 3 — paid, billing su GCP
#   "gemini_image" = Gemini 2.5 Flash Image — paid
#   "wikimedia"    = Wikimedia Commons (CC, gratis)
#   "unsplash"     = Unsplash stock (free, richiede UNSPLASH_ACCESS_KEY)
#   "none"         = solo gradient brand
# --- Instagram publishing (Meta Graph API) ---
# Setup (vedi /api/publish/status per diagnostica):
# 1. App su developers.facebook.com → tipo Business
# 2. Aggiungi prodotto Instagram + collega un Business/Creator account a una Page
# 3. Compila qui sotto, poi OAuth flow via /api/publish/oauth/start
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/publish/oauth/callback
IG_LONG_LIVED_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
# URL pubblico HTTPS dove Meta puo' scaricare le immagini. In dev usa ngrok:
#   ngrok http 8000 → copia l'URL https://xxx.ngrok-free.app qui sotto
PUBLIC_BASE_URL=

DEFAULT_IMAGE_SOURCE=pollinations
IMAGEN_MODEL=imagen-3.0-generate-002
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
POLLINATIONS_MODEL=flux
UNSPLASH_ACCESS_KEY=
